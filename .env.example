DATABASE_URL="file:./dev.db"

# Public launch: set to true to remove invite requirement and amplify discovery/gravity
# PUBLIC_LAUNCH_MODE=true

# Event bus: memory (default) or redis for production scale
# EVENT_BUS_PROVIDER=memory
# REDIS_URL=redis://localhost:6379

# NextAuth (Auth.js) — required for Google, Email, Wallet login
# AUTH_SECRET: run `npx auth secret` or use a long random string
# AUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# WalletConnect (RainbowKit) — https://cloud.walletconnect.com
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Email magic link (optional) — Resend
# AUTH_RESEND_KEY=
# AUTH_EMAIL_FROM=Chaotix <noreply@example.com>

# Legacy OAuth (Google + Facebook)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# NEXT_PUBLIC_FACEBOOK_APP_ID=...
# FACEBOOK_APP_SECRET=...
