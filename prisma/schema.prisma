generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  email               String?   @unique
  emailVerified       DateTime?
  passwordHash        String?
  name                String?
  image               String?
  walletAddress       String?   @unique  // primary wallet for SIWE login
  referralCode        String    @unique
  referredById        String?
  referredBy          User?     @relation("Referrals", fields: [referredById], references: [id])
  referredUsers       User[]    @relation("Referrals")
  referralStatus      String    @default("NONE")   // NONE | PENDING | APPROVED (Partner program)
  twitterHandle       String?
  discordHandle       String?
  telegramHandle      String?
  referralPitch       String?
  partnerShortSlug    String?   @unique            // e.g. "zura" -> chaotix.io/r/zura
  referralApplications ReferralApplication[]
  balance             Float     @default(1000)
  isBanned            Boolean   @default(false)
  isAdmin             Boolean   @default(false)
  reputationScore     Float     @default(0)
  successfulTrades    Int       @default(0)
  marketInfluenceScore Float    @default(0)
  badges              String    @default("[]")
  trustLevel          Int       @default(0)
  marketCreationLimit Int       @default(5)
  flaggedAt           DateTime?
  suspiciousScore     Float     @default(0)
  botProbability      Float     @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  trustScore         Float     @default(0)
  marketplaceVerifiedAt DateTime?  // Phase 4: verified badge
  marketplaceTrustScore Float   @default(0)   // 0-100 from trades, disputes, feedback
  marketplaceCompletedTrades Int @default(0)  // cached count for trust
  waitlistStatus     String    @default("none")   // none | waitlisted | invited | active
  inviteCodeUsed     String?   // code used to redeem access
  isFoundingTrader   Boolean   @default(false)
  marketsCreated     Int       @default(0)
  successfulMarkets Int       @default(0)
  seasonScore        Float     @default(0)   // seasonal competition: composite score for current period
  roiRank            Int       @default(0)   // current period ROI rank (0 = unranked)
  volumeRank         Int       @default(0)   // current period volume rank
  narrativeRank      Int       @default(0)   // current period narrative discovery rank
  rankTitle          String?   // e.g. Narrative Hunter, Signal Trader, Market Architect
  creatorRewardTier  Int       @default(0)   // creator incentive: 0–4 for milestones 100/500/1000 trades, 10k volume
  creatorVolumeGenerated Float @default(0)  // total volume across all markets created by this user
  positions         Position[]
  trades            Trade[]
  creatorRewards    CreatorReward[]
  referralEarnings   ReferralEarning[]
  auditLogs          AuditLog[]
  marketComments    MarketComment[]
  marketPosts       MarketPost[]
  liquidityPositions LiquidityPosition[]
  walletAccounts    WalletAccount[]
  userBalance      UserBalance?
  deposits         Deposit[]
  depositAddresses DepositAddress[]
  notifications     Notification[]
  username          String?   @unique
  followers         UserFollow[] @relation("FollowFollowers")
  following         UserFollow[] @relation("FollowFollowing")
  copyTradingAsFollower CopyTrading[] @relation("CopyFollower")
  copyTradingAsTrader   CopyTrading[] @relation("CopyTrader")
  activities        Activity[]
  seasonRanks      SeasonRank[]
  marketProposals   MarketProposal[]
  proposalUpvotes  ProposalUpvote[]

  // Marketplace (universal Asset / order-book)
  createdAssets    Asset[]
  assetTradesAsBuyer  AssetTrade[] @relation("AssetTradeBuyer")
  assetTradesAsSeller AssetTrade[] @relation("AssetTradeSeller")
  auctionsCreated  Auction[]
  auctionBids      AuctionBid[]
  assetHoldings    AssetHolding[]
  marketplaceWatchlist MarketplaceWatchlist[]
  marketplaceReportsFiled   MarketplaceReport[] @relation("ReportReporter")
  marketplaceDisputesOpened MarketplaceDispute[]
  tradeFeedbackGiven   TradeFeedback[] @relation("FeedbackFrom")
  tradeFeedbackReceived TradeFeedback[] @relation("FeedbackTo")
  escrowsAsSeller  MarketplaceEscrow[] @relation("EscrowSeller")
  escrowsAsBuyer   MarketplaceEscrow[] @relation("EscrowBuyer")
  assetComments    AssetComment[]
  assetShares      AssetShare[]
  assetBundles     AssetBundle[]
  assetPriceAlerts AssetPriceAlert[]
  orders           Order[]

  oauth_provider   String?   // legacy: 'google' | 'facebook'
  oauth_id         String?   // legacy provider user id
  oauth_email      String?   // legacy
  oauth_token      String?   // legacy
  oauth_picture    String?   // legacy; prefer image

  accounts         Account[]
  sessions         Session[]

  @@unique([oauth_provider, oauth_id])
  @@index([referralCode])
  @@index([referralStatus])
  @@index([partnerShortSlug])
  @@index([trustScore])
  @@index([waitlistStatus])
  @@index([username])
  @@index([oauth_provider, oauth_id])
  @@index([walletAddress])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires   DateTime

  @@unique([identifier, token])
}

model WalletAccount {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String
  chain         String    // ethereum | polygon | solana
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@unique([chain, walletAddress])
  @@index([userId])
  @@index([walletAddress])
  @@index([userId, chain])
}

model UserBalance {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Float    @default(0)
  lockedBalance Float    @default(0)
  version       Int      @default(0)  // optimistic locking
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Deposit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  method    String   // crypto | paypal | card
  asset     String   // USDC | USD | etc.
  amount    Float
  status    String   @default("pending") // pending | confirmed | failed
  txHash    String?
  externalId String? // PayPal order ID, Stripe payment intent ID, etc.
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model DepositAddress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chain     String   // ethereum | polygon | solana
  address   String
  createdAt DateTime @default(now())

  @@unique([userId, chain])
  @@index([userId])
  @@index([address])
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  maxUses   Int      @default(1)
  usedCount Int      @default(0)
  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@index([code])
}

model ReferralApplication {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  twitterHandle  String?
  discordHandle  String?
  telegramHandle String?
  pitch          String?   // 500 chars max
  status         String    @default("pending")  // pending | approved | rejected
  createdAt      DateTime  @default(now())
  reviewedAt     DateTime?
  reviewedById   String?

  @@index([userId])
  @@index([status])
}

model Market {
  id                  String    @id @default(cuid())
  canonical           String    @unique
  displayName         String
  title               String?
  description         String?
  tags                String    @default("[]")
  price               Float     @default(0.01)
  volume              Float     @default(0)
  volume24h           Float     @default(0)
  priceChange24h      Float     @default(0)
  tradeCount          Int       @default(0)
  reserveTokens       Float     @default(0)
  reserveShares       Float     @default(0)
  categoryId          String?
  category            Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  phase               String    @default("creation")
  status              String    @default("active")
  momentumScore       Float     @default(0)
  circuitBreakerUntil DateTime?
  createdById         String?
  lastTradeAt         DateTime?
  archivedAt          DateTime?
  flaggedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  conceptHash        String?   // for merge/similarity
  totalLpTokens      Float     @default(0)
  totalLpFeesAccrued Float     @default(0)
  isVerified         Boolean   @default(false)
  verifiedAt         DateTime?
  gravityScore       Float     @default(0)
  survivalScore      Float     @default(0)
  eventId            String?   // e.g. tech_week, creator_week
  stage              String    @default("emerging")  // emerging | active | established | legendary | dead
  version            Int       @default(0)  // optimistic locking for trade execution
  // Narrative Strength Index (NSI): price ∈ [0,1] = collective attention/belief in narrative
  narrativeScore     Float?    // optional override; when null, use price as NSI
  attentionVelocity  Float     @default(0) // rate of change of attention (e.g. NSI delta over 1h)
  uniqueTraders24h   Int       @default(0)  // distinct traders in last 24h
  socialMomentum     Float     @default(0) // composite: comments, follows, copy-trades signal
  volumeAcceleration Float     @default(0) // volume 24h vs prior 24h (growth rate)
  volatilityFactor   Float     @default(1)  // market activity simulation: scale for trade size/volatility
  minDailyTrades     Int       @default(0) // market activity simulation: target min trades per day (0 = no seeding)
  positions          Position[]
  creatorRewards     CreatorReward[]
  marketMetrics      MarketMetrics?
  trades             Trade[]
  priceHistory       PricePoint[]
  comments           MarketComment[]
  posts              MarketPost[]
  liquidityPositions  LiquidityPosition[]
  liquidityPool       LiquidityPool?
  earlyTraders        MarketEarlyTrader[]
  attentionSignals    AttentionSignal[]
  moderationEntries   ModerationQueue[]
  marketReputation    MarketReputation?
  marketCreationFees  MarketCreationFee[]
  liquidityRewards    LiquidityReward[]
  suspiciousActivities SuspiciousActivity[]
  entityLinks         MarketEntityLink[]
  clusterMembers      MarketClusterMember[]
  sentiment           MarketSentiment?
  ownerships          MarketOwnership[]
  narrativeEvents    NarrativeEvent[]
  narrativeClusterMembers NarrativeClusterMember[]
  proposals         MarketProposal[]
  isCoreMarket      Boolean   @default(false)  // curated narrative; only these + high-volume show in discovery

  @@index([tradeCount])
  @@index([volume])
  @@index([lastTradeAt])
  @@index([status])
  @@index([momentumScore])
  @@index([conceptHash])
  @@index([gravityScore])
  @@index([eventId])
  @@index([stage])
  @@index([createdById])
  @@index([categoryId])
  @@index([createdAt])
  @@index([volume24h])
  @@index([isCoreMarket])
}

model NarrativeEvent {
  id           String   @id @default(cuid())
  marketId     String
  market       Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  source       String?  // e.g. "Reuters", "Twitter", "Community"
  timestamp    DateTime @default(now())
  impactScore  Float    @default(0)  // -1 to 1 or 0 to 1; used for attentionVelocity/momentum
  reactionCount Int    @default(0)  // community reactions (upvotes, comments)
  createdAt    DateTime @default(now())

  @@index([marketId])
  @@index([marketId, timestamp])
  @@index([timestamp])
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  markets     Market[]
}

model MarketEvent {
  id          String   @id @default(cuid())
  slug        String   @unique   // tech_week, creator_week, ai_week
  name        String
  startAt     DateTime
  endAt       DateTime
  boostFactor Float    @default(1.2)   // trending multiplier
  createdAt   DateTime @default(now())
}

model PricePoint {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  price     Float
  timestamp DateTime @default(now())

  @@index([marketId])
}

model Position {
  id           String    @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId     String
  market       Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  shares       Float     @default(0)
  avgPrice     Float     @default(0)
  totalBought  Float     @default(0)
  totalSold    Float     @default(0)
  realizedPnL  Float     @default(0)
  createdAt    DateTime  @default(now())
  lastTradeAt  DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([userId, marketId])
  @@index([marketId])
  @@index([userId])
}

model CreatorReward {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  reward    Float
  reason    String
  createdAt DateTime @default(now())

  @@index([marketId])
  @@index([userId])
}

model MarketMetrics {
  marketId       String   @id
  market         Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  volume24h      Float     @default(0)
  traderCount24h Int      @default(0)
  priceChange24h Float     @default(0)
  updatedAt      DateTime @updatedAt
}

model Trade {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId      String
  market        Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  side          String
  shares        Float
  price         Float
  total         Float
  fee           Float    @default(0)
  feeToReferrer Float    @default(0)
  referrerId    String?
  realizedPnLContribution Float?  // set on sell: PnL realized by this trade (for period leaderboards)
  isSystemTrade Boolean  @default(false)  // market activity simulation; excluded from leaderboards
  createdAt     DateTime @default(now())

  settlements     TradeSettlement[]
  referencedPosts MarketPost[]

  @@index([marketId])
  @@index([userId])
  @@index([createdAt])
  @@index([marketId, createdAt])
  @@index([userId, createdAt])
  @@index([isSystemTrade])
}

model TradeSettlement {
  id        String   @id @default(cuid())
  tradeId   String
  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  status    String   // pending | submitted | confirmed | failed
  txHash    String?
  chain     String?
  settledAt DateTime?
  createdAt DateTime @default(now())

  @@unique([tradeId])
  @@index([status])
}

model ReferralEarning {
  id         String   @id @default(cuid())
  referrerId String
  referrer   User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  tradeId    String?
  amount     Float
  createdAt  DateTime @default(now())

  @@index([referrerId])
  @@index([createdAt])
  @@index([referrerId, createdAt])
}

model TradeAttempt {
  id        String   @id @default(cuid())
  userId    String?
  marketId  String?
  action    String
  payload   String?
  error     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AdminAlert {
  id         String    @id @default(cuid())
  type       String
  severity   String    @default("medium")
  resource   String?
  resourceId String?
  message    String
  payload    String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String
  userId    String?
  marketId  String?
  payload   String?
  createdAt DateTime @default(now())
}

model MarketComment {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  sentiment String?
  createdAt DateTime @default(now())

  @@index([marketId])
  @@index([userId])
}

model MarketPost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  content   String
  likes     Int      @default(0)
  tradeId   String?
  trade     Trade?   @relation(fields: [tradeId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([marketId])
  @@index([userId])
  @@index([marketId, likes])
  @@index([marketId, createdAt])
  @@index([tradeId])
}

model Season {
  id           String    @id @default(cuid())
  name         String    // e.g. "Narrative Wars"
  slug         String    @unique  // e.g. "narrative-wars"
  startAt      DateTime
  endAt        DateTime
  description  String?
  topRankCount Int       @default(100)  // top N earn permanent rank
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ranks SeasonRank[]

  @@index([startAt])
  @@index([endAt])
}

model SeasonRank {
  id                 String   @id @default(cuid())
  seasonId           String
  season             Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rank                Int      // 1-based final rank (e.g. 1-100)
  roiScore            Float    @default(0)   // period ROI % or points
  narrativeScore      Float    @default(0)   // narrative discovery points
  volumeScore         Float    @default(0)   // trading volume in period
  permanentRankTitle  String?   // e.g. "Narrative Wars Top 50"
  badgeAwarded        String?   // e.g. "narrative_wars_top_100"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([seasonId, userId])
  @@index([seasonId])
  @@index([userId])
  @@index([seasonId, rank])
}

model SystemHealthMetric {
  id        String   @id @default(cuid())
  kind      String
  value     Float
  payload   String?
  createdAt DateTime @default(now())

  @@index([kind])
  @@index([createdAt])
}

model LiquidityPool {
  id             String   @id @default(cuid())
  marketId       String   @unique
  market         Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  totalLiquidity Float    @default(0)
  totalLpShares  Float    @default(0)
  createdAt      DateTime @default(now())

  @@index([marketId])
}

model LiquidityPosition {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId        String
  market          Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  tokensDeposited Float    @default(0)
  sharesDeposited Float    @default(0)
  lpTokens        Float    @default(0)
  feesEarned      Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, marketId])
  @@index([marketId])
  @@index([userId])
  @@index([userId, createdAt])
}

model MarketCreationFee {
  id        String   @id @default(cuid())
  userId    String
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  amount    Float
  refunded  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([marketId])
  @@index([userId])
}

model LiquidityReward {
  id        String   @id @default(cuid())
  userId    String
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  reward    Float
  reason    String
  createdAt DateTime @default(now())

  @@index([marketId])
  @@index([userId])
}

model MarketReputation {
  marketId        String   @id
  market          Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  traderCount     Int      @default(0)
  tradeCount      Int      @default(0)
  volumeScore     Float    @default(0)
  ageScore        Float    @default(0)
  reputationScore Float    @default(0)
  updatedAt       DateTime @updatedAt
}

model SuspiciousActivity {
  id        String   @id @default(cuid())
  userId    String?
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  type      String
  details   String   // JSON
  createdAt DateTime @default(now())

  @@index([marketId])
  @@index([userId])
  @@index([type])
}

model MarketEarlyTrader {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  userId    String
  rank      Int      // 1 = first trader
  createdAt DateTime @default(now())

  @@unique([marketId, userId])
  @@index([marketId])
  @@index([userId])
}

model AttentionSignal {
  id               String   @id @default(cuid())
  marketId         String
  market           Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  source           String   // internal_trading | comment_activity | market_views | unique_visitors
  attentionScore   Float    @default(0)
  attentionVelocity Float   @default(0)
  attentionTrend   Float    @default(0)
  windowStart      DateTime @default(now())
  windowEnd        DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([marketId])
  @@index([source])
  @@index([createdAt])
}

model ManipulationAlert {
  id         String    @id @default(cuid())
  type       String    // coordinated_pump | referral_farm | trade_ring | volume_spoof
  severity   String    @default("medium")
  resource   String?
  resourceId String?
  message    String
  payload    String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([type])
  @@index([createdAt])
}

model PlatformToken {
  id              String   @id @default(cuid())
  kind            String   // fee_collected | lp_incentive | referral_payout | treasury
  amount          Float    @default(0)
  referenceId     String?  // tradeId, marketId, etc.
  payload         String?  // JSON details
  createdAt       DateTime @default(now())

  @@index([kind])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // price_spike | gravity_market | market_you_hold_moving | market_created_about_you | referral_trade | liquidity_opportunity
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  payload   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
}

model MarketAlias {
  id         String   @id @default(cuid())
  canonical  String   // primary market canonical
  alias      String   @unique  // variant: mbappe, kylian mbappe, mbappé, k.mbappe
  normalized String   // normalized form for clustering
  createdAt  DateTime @default(now())

  @@index([canonical])
  @@index([normalized])
}

model MarketProposal {
  id                String    @id @default(cuid())
  proposedCanonical  String   // user-submitted identifier (e.g. gpt, artificial-intelligence)
  resolvedCanonical  String   // after alias resolution (e.g. ai) — used to prevent duplicates
  title              String?
  description        String?
  proposedById       String
  proposer           User     @relation(fields: [proposedById], references: [id], onDelete: Cascade)
  status             String   @default("pending")  // pending | approved | rejected
  marketId           String?  // set when approved and market created
  market             Market?  @relation(fields: [marketId], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  upvotes ProposalUpvote[]

  @@index([proposedById])
  @@index([status])
  @@index([resolvedCanonical])
  @@index([createdAt])
}

model ProposalUpvote {
  id         String         @id @default(cuid())
  proposalId String
  proposal   MarketProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([proposalId, userId])
  @@index([proposalId])
  @@index([userId])
}

model ModerationQueue {
  id         String    @id @default(cuid())
  marketId   String
  market     Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  reason     String    // illegal | harassment | spam
  status     String    @default("pending")  // pending | reviewed | approved | removed
  reviewedBy String?
  reviewedAt DateTime?
  payload    String?
  createdAt  DateTime  @default(now())

  @@index([marketId])
  @@index([status])
}

// ---------- Phase 8: Intelligence ----------
model MarketEntity {
  id        String   @id @default(cuid())
  name      String
  type      String   // person | event | topic | org
  normalized String  @unique
  createdAt DateTime @default(now())
  links     MarketEntityLink[]

  @@index([type])
  @@index([normalized])
}

model MarketEntityLink {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  entityId  String
  entity    MarketEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  relevance Float    @default(1)

  @@index([marketId])
  @@index([entityId])
}

model MarketCluster {
  id       String   @id @default(cuid())
  name     String
  createdAt DateTime @default(now())
  members  MarketClusterMember[]

  @@index([name])
}

model MarketClusterMember {
  id         String   @id @default(cuid())
  clusterId  String
  cluster    MarketCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  marketId   String
  market     Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  similarity Float    @default(1)

  @@unique([clusterId, marketId])
  @@index([clusterId])
  @@index([marketId])
}

model NarrativeCluster {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?  // emoji or icon name
  createdAt   DateTime @default(now())
  members     NarrativeClusterMember[]

  @@index([slug])
}

model NarrativeClusterMember {
  id         String   @id @default(cuid())
  clusterId  String
  cluster    NarrativeCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  marketId   String
  market     Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([clusterId, marketId])
  @@index([clusterId])
  @@index([marketId])
}

/// Narrative Intelligence: time-series snapshots for index-over-time charts (clusterIndex = average(narrativeStrength) per cluster).
model NarrativeIndexSnapshot {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  globalIndex      Float    // 0–100
  aiIndex          Float
  cryptoIndex      Float
  geopoliticsIndex Float
  technologyIndex  Float

  @@index([createdAt])
}

model MarketSentiment {
  marketId     String   @id
  market       Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  bullishScore Float    @default(0)
  bearishScore Float    @default(0)
  neutralScore Float    @default(0)
  updatedAt    DateTime @updatedAt
}

// ---------- Phase 9: Network effects ----------
model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("FollowFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model CopyTrading {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("CopyFollower", fields: [followerId], references: [id], onDelete: Cascade)
  traderId    String
  trader      User     @relation("CopyTrader", fields: [traderId], references: [id], onDelete: Cascade)
  allocation  Float    @default(1)
  createdAt   DateTime @default(now())

  @@unique([followerId, traderId])
  @@index([followerId])
  @@index([traderId])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // trade | market_created | market_trending | liquidity_added | referral_joined
  payload   String?  // JSON
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([userId, createdAt])
}

// ---------- Phase 10: Protocol ----------
model MarketOwnership {
  id       String   @id @default(cuid())
  marketId String
  market   Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  ownerId  String
  share   Float    @default(0)

  @@index([marketId])
  @@index([ownerId])
}

model GovernanceProposal {
  id          String   @id @default(cuid())
  title       String
  description String
  createdBy   String
  status      String   @default("active")  // active | passed | rejected | cancelled
  createdAt   DateTime @default(now())
  votes       GovernanceVote[]

  @@index([status])
  @@index([createdAt])
}

model GovernanceVote {
  id         String   @id @default(cuid())
  proposalId String
  proposal   GovernanceProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId     String
  vote       String   // for | against | abstain

  @@unique([proposalId, userId])
  @@index([proposalId])
  @@index([userId])
}

model TreasuryTransfer {
  id        String   @id @default(cuid())
  amount    Float
  reason    String   // liquidity_incentive | creator_program | growth_campaign | other
  createdAt DateTime @default(now())

  @@index([reason])
  @@index([createdAt])
}

// ---------- Marketplace: universal Asset + order-book price discovery ----------
// Supply: fixed (totalSupply set, no mint) | limited (maxSupply) | unlimited (null maxSupply)
// Lowest ask = sell price; highest bid = buy pressure; market price = last trade

model Asset {
  id                 String   @id @default(cuid())
  title              String
  category           String   // e.g. player, stock, collectible, service
  description        String?
  creatorId          String
  creator            User     @relation(fields: [creatorId], references: [id], onDelete: Restrict)
  supplyModel        String   // fixed | limited | unlimited
  totalSupply        Float    @default(0)   // circulating supply
  maxSupply          Float?   // null = unlimited
  currentPrice       Float    @default(0)   // last trade price; updated on each trade
  marketCap          Float    @default(0)   // currentPrice * totalSupply (denormalized)
  liquidityScore     Float    @default(0)   // 0–100: trade volume + traders + spread + depth
  demandScore        Float    @default(0)   // Phase 3: weighted views, bids, volume, new buyers (0–100)
  trendingScore      Float    @default(0)   // Phase 3: recent activity with time decay (0–100)
  volume24h          Float    @default(0)   // cached for liquidity
  activeTraders24h   Int      @default(0)   // cached for liquidity
  priceChange24h     Float    @default(0)   // (current - price 24h ago) / max(price 24h ago, 0.01)
  viewCount24h       Int      @default(0)   // Phase 3: page views last 24h
  searchCount24h     Int      @default(0)   // Phase 3: searches last 24h
  watcherCount       Int      @default(0)   // Phase 3: watchlist count (cached)
  commentCount       Int      @default(0)   // Phase 5: discussion volume
  shareCount         Int      @default(0)   // Phase 5: share count
  communitySentimentScore Float @default(50) // Phase 5: 0-100 from feedback/comments
  newBids24h         Int      @default(0)   // Phase 3: new bids last 24h
  externalMentions24h Int     @default(0)   // Phase 3: external mentions last 24h
  newBuyers24h       Int      @default(0)   // Phase 3: unique buyers last 24h
  tradeCount24h      Int      @default(0)   // Phase 3: number of trades last 24h
  rankingsUpdatedAt  DateTime?              // last time demand/trending was recomputed
  verificationStatus String   @default("unverified")  // unverified | pending | verified
  frozenAt           DateTime?              // Phase 4: when set, listings hidden / no new trades
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  metadata           String?  // JSON: tags[], media[], externalRefs[]
  marketMetrics      AssetMarketMetrics?

  trades      AssetTrade[]
  priceHistory AssetPricePoint[]
  auctions    Auction[]
  holdings    AssetHolding[]
  watchlist   MarketplaceWatchlist[]
  pageViews   AssetPageView[]
  searches    AssetSearch[]
  externalMentions AssetExternalMention[]
  comments   AssetComment[]
  shares     AssetShare[]
  priceAlerts AssetPriceAlert[]
  orders     Order[]
  orderBookSnapshot OrderBookSnapshot?

  @@index([creatorId])
  @@index([trendingScore])
  @@index([demandScore])
  @@index([volume24h])
  @@index([tradeCount24h])
  @@index([category])
  @@index([verificationStatus])
  @@index([currentPrice])
  @@index([createdAt])
}

model AssetPricePoint {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  price     Float
  timestamp DateTime @default(now())

  @@index([assetId])
  @@index([assetId, timestamp])
}


model AssetTrade {
  id         String   @id @default(cuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  buyerId    String
  buyer      User     @relation("AssetTradeBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId  String
  seller     User     @relation("AssetTradeSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  quantity   Float
  unitPrice  Float    // execution price (updates asset.currentPrice)
  createdAt  DateTime @default(now())

  dispute    MarketplaceDispute?
  escrow     MarketplaceEscrow?
  feedback   TradeFeedback[]

  @@index([assetId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([assetId, createdAt])
}

model Auction {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  quantity    Float
  startAt     DateTime
  endAt       DateTime
  minBid      Float
  status       String     @default("active")  // active | won | cancelled
  winningBidId String?    @unique
  winningBid   AuctionBid? @relation("AuctionWinningBid", fields: [winningBidId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  bids         AuctionBid[]

  @@index([assetId])
  @@index([sellerId])
  @@index([status])
  @@index([endAt])
}

model AuctionBid {
  id         String   @id @default(cuid())
  auctionId   String
  auction     Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidderId    String
  bidder      User     @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  amount      Float
  createdAt   DateTime @default(now())
  winningAuction Auction? @relation("AuctionWinningBid")

  @@index([auctionId])
  @@index([bidderId])
}

model AssetHolding {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  quantity  Float    @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, assetId])
  @@index([userId])
  @@index([assetId])
}

model MarketplaceWatchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, assetId])
  @@index([userId])
  @@index([assetId])
}

// Phase 3: demand signals for trending/hype
model AssetPageView {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId    String?  // nullable for anonymous
  createdAt DateTime @default(now())

  @@index([assetId])
  @@index([assetId, createdAt])
}

model AssetSearch {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId    String?
  query     String?
  createdAt DateTime @default(now())

  @@index([assetId])
  @@index([assetId, createdAt])
}

model AssetExternalMention {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  source    String?  // twitter, news, etc.
  createdAt DateTime @default(now())

  @@index([assetId])
  @@index([assetId, createdAt])
}

// Phase 4: Trust, verification, anti-scam
model MarketplaceReport {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resourceType String  // "asset" | "user"
  resourceId  String   // asset id or user id
  reason      String   // scam, inappropriate, copyright, other
  details     String?
  status      String   @default("pending")  // pending | reviewed | dismissed
  reviewedAt  DateTime?
  reviewedById String?
  createdAt   DateTime @default(now())

  @@index([reporterId])
  @@index([resourceType, resourceId])
  @@index([status])
}

model MarketplaceDispute {
  id             String   @id @default(cuid())
  tradeId        String   @unique
  trade          AssetTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  openedById     String
  openedBy       User     @relation(fields: [openedById], references: [id], onDelete: Cascade)
  reason         String
  status         String   @default("open")  // open | resolved_buyer | resolved_seller | dismissed
  resolutionNote String?
  resolvedAt     DateTime?
  resolvedById   String?
  createdAt      DateTime @default(now())

  @@index([openedById])
  @@index([status])
}

model TradeFeedback {
  id        String   @id @default(cuid())
  tradeId   String
  trade     AssetTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser  User     @relation("FeedbackFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId  String
  toUser    User     @relation("FeedbackTo", fields: [toUserId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  @@unique([tradeId, fromUserId, toUserId])
  @@index([tradeId])
  @@index([toUserId])
}

model MarketplaceEscrow {
  id         String   @id @default(cuid())
  tradeId    String   @unique
  trade      AssetTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  assetId    String
  sellerId   String
  seller     User     @relation("EscrowSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  buyerId    String
  buyer      User     @relation("EscrowBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  quantity   Float
  unitPrice  Float
  status     String   @default("held")  // held | released | refunded
  releasedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([sellerId])
  @@index([buyerId])
  @@index([status])
}

// Phase 5: Social layer
model AssetComment {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   // max ~2000 chars
  parentId  String?  // optional reply to another comment
  createdAt DateTime @default(now())

  @@index([assetId])
  @@index([userId])
  @@index([assetId, createdAt])
}

model AssetShare {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([assetId])
  @@index([userId])
  @@index([assetId, createdAt])
}

// Phase 6: Creator economy - bundles/collections
model AssetBundle {
  id          String   @id @default(cuid())
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title       String
  description String?
  assetIds    String   // JSON array of asset ids
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([creatorId])
}

// Phase 7: Price alerts for notifications
model AssetPriceAlert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  direction String   // above | below
  threshold Float
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, assetId])
  @@index([userId])
  @@index([assetId])
}

// Phase 6+: Professional order book (adds Order as canonical order abstraction)
model Order {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type           String   // buy | sell
  orderType      String   // limit | market
  price          Float?   // required for limit; null for market
  quantity       Float
  filledQuantity Float    @default(0)
  status         String   @default("open") // open | partial | filled | cancelled
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([assetId])
  @@index([assetId, status])
  @@index([createdAt])
}

model OrderBookSnapshot {
  assetId   String   @id
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  bids      String   // JSON: [{price, quantity, cumulative?}...]
  asks      String   // JSON: [{price, quantity, cumulative?}...]
  updatedAt DateTime @updatedAt
}

model AssetMarketMetrics {
  id               String   @id @default(uuid())
  assetId          String   @unique
  volume24h        Float    @default(0)
  high24h          Float?
  low24h           Float?
  vwap             Float?
  liquidityScore   Float    @default(0)
  spreadPercentage Float?
  updatedAt        DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}
