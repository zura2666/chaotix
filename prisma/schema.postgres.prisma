// Production schema for PostgreSQL.
// Use: cp schema.postgres.prisma schema.prisma && prisma migrate dev
// Or set DATABASE_URL to Postgres and run: prisma migrate deploy

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  passwordHash  String?
  name          String?
  referralCode  String    @unique
  referredById  String?
  referredBy    User?     @relation("Referrals", fields: [referredById], references: [id])
  referredUsers User[]    @relation("Referrals")
  balance       Float     @default(1000)
  isBanned      Boolean   @default(false)
  isAdmin       Boolean   @default(false)
  reputationScore Float   @default(0)
  badges         String  @default("[]")
  flaggedAt      DateTime?
  suspiciousScore Float   @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  positions     Position[]
  trades        Trade[]
  referralEarnings ReferralEarning[]
  auditLogs     AuditLog[]

  @@index([referralCode])
}

model Market {
  id             String    @id @default(cuid())
  canonical      String    @unique
  displayName    String
  title          String?
  description    String?
  tags           String    @default("[]")
  price          Float     @default(0.01)
  volume        Float     @default(0)
  tradeCount     Int       @default(0)
  reserveTokens  Float     @default(0)
  reserveShares  Float     @default(0)
  category       String?
  phase          String    @default("creation")
  circuitBreakerUntil DateTime?
  createdById    String?
  lastTradeAt    DateTime?
  flaggedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  positions Position[]
  trades    Trade[]
  priceHistory PricePoint[]

  @@index([canonical])
  @@index([tradeCount])
  @@index([volume])
  @@index([lastTradeAt])
  @@index([phase])
}

model PricePoint {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  price     Float
  timestamp DateTime @default(now())

  @@index([marketId, timestamp])
}

model Position {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  shares    Float    @default(0)
  avgPrice  Float    @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, marketId])
  @@index([marketId])
  @@index([userId])
}

model Trade {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId      String
  market        Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  side          String
  shares        Float
  price         Float
  total         Float
  fee           Float    @default(0)
  feeToReferrer Float    @default(0)
  referrerId    String?
  createdAt     DateTime @default(now())

  @@index([marketId])
  @@index([userId])
  @@index([createdAt])
  @@index([marketId, createdAt])
}

model ReferralEarning {
  id         String   @id @default(cuid())
  referrerId String
  referrer   User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  tradeId    String?
  amount     Float
  createdAt  DateTime @default(now())
}

model TradeAttempt {
  id        String   @id @default(cuid())
  userId    String?
  marketId  String?
  action    String
  payload   String?
  error     String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AdminAlert {
  id        String   @id @default(cuid())
  type      String
  severity  String   @default("medium")
  resource  String?
  resourceId String?
  message   String
  payload   String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([readAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String
  userId    String?
  marketId  String?
  payload   String?
  createdAt DateTime @default(now())

  @@index([name])
  @@index([createdAt])
}
